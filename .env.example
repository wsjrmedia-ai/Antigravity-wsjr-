VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Leverate / Sirix Trading API (ManagementService)
# Bearer token is kept server-side only — never sent to the browser
LEVERATE_BASE_URL=https://restapi-real.sirixtrader.com:443
LEVERATE_BEARER_TOKEN=your_leverate_bearer_token_here
# The Leverate account ID to load positions/balance for
VITE_LEVERATE_USER_ID=your_leverate_user_id_here

# Anthropic (Claude) — used by the Express backend for /api/claude-stream
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Other backend keys
PERPLEXITY_API_KEY=your_perplexity_key_here
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:5173
PORT=3001
